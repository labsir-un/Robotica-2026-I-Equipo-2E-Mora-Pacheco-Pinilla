    CONST jointtarget Home_ABS:= [[0,0,0,0,30,0],[9E+09,9E+09,9E+09,9E+09,9E+09,9E+09]];
    CONST jointtarget Mantenimiento_Point:= [[90,0,0,0,30,0],[9E+09,9E+09,9E+09,9E+09,9E+09,9E+09]];
    !***********************************************************
    !
    ! M?dulo:  Module1
    !
    ! Descripción:
    !   <Introduzca la descripción aquí>
    !
    ! Autor: pache
    !
    ! Versión: 1.0
    !
    !***********************************************************
    
    
    !***********************************************************
    !
    ! Procedimiento Main
    !
    !   Este es el punto de entrada de su programa
    !
PROC main()
      
        ! Limpiamos la pantalla del control virtual
        TPErase;
        TPWrite "SISTEMA INICIADO";
        
        MoveAbsJ Home_ABS, v300, z1, tool0;
        
        TPWrite "INICIO PROGRAMA";
        TPWrite "APAGADO BANDA TRANASPORTADORA";
        Reset DO_02;
        Reset DO_01;
        RESET BWD_Conveyor;
        RESET FWD_Conveyor;
        
        

        
        ! 1. Apagamos la banda por seguridad al arrancar
        
        WHILE TRUE DO
            
            IF DI_03 = 1 THEN
                Set BWD_Conveyor;
                WaitTime 4.275; 
                Reset FWD_Conveyor;
                Reset BWD_Conveyor;
            ENDIF
            
            
            TPWrite "ESPERANDO QUE PRESIONE DI_01...";
            ! 2. Esperamos el botón de inicio
            IF DI_01 = 1 AND DI_02 = 0 THEN
                    
                
                    
                    
                    TPWrite "MOVIENDO CAJA...";
                
                    ! 3. Encendemos la banda
                    set FWD_Conveyor;
                    set DO_01;
                    
                    ! 4. Tiempo de viaje (ajustado a tu prueba)
                    WaitTime 4.275;
                    
                    ! 5. Detenemos la caja
                    Reset FWD_Conveyor;
                    TPWrite "CAJA EN POSICION - INICIANDO GRABADO";
            
                    ! --------------------------------------------------------
                    ! 6. LLAMADA A LAS TRAYECTORIAS
                    Path_aprox;
                    WaitTime 1;
                    Path_duvan;
                    Path_mora;
                    Path_gusta;
                    Path_robot;
                    Path_220;
                    WaitTime 2;
                    Path_home;
                    WaitTime 5;
                    reset DO_01;
                    
                ELSEIF DI_01 = 0 AND DI_02=1 THEN
                Set DO_02;
                TPWrite "RUTINA CAMBIO DE HERRAMIENTA";
                MoveAbsJ Mantenimiento_Point,v100,z1,tool0;
                TPWrite "PELIGRO";  
                TPWrite "OPERARIO CERCA A HERRAMIENTA";   
                TPWrite "PRESIONE LOS DOS BOTONES PARA CONTINUAR EL PROGRAMA"; 
                WaitDI DI_01,1;
                WaitDI DI_02,1;
                Reset DO_02;
                TPWrite "REANUDANDO PROGRAMA"; 
                WaitTime 3;
                MoveAbsJ Home_ABS,v100,z1,tool0;
                ELSEIF DI_01 = 0 AND DI_02=0 THEN
                TPWrite "ESPERANDO INSTRUCCIÓNES";  
                ELSEIF DI_01 = 1 AND DI_02=1 THEN
                TPWrite "ERROR";   
                TPWrite "NO DEBE PRESIONAR AMBAS ENTRADAS AL TIEMPO";   
            ENDIF       
            
            TPWrite "CICLO TERMINADO. MUEVA LA CAJA AL INICIO.";
        ENDWHILE
        WaitTime 1.0;
    ENDPROC
    
    
   
    
    PROC Path_aprox()
        MoveL Target_home,v100,z1,MarcadorVirtual\WObj:=wobj0;
        MoveL Target_aprox1,v100,z1,MarcadorVirtual\WObj:=wobj0;
        MoveL Target_aprox2,v100,z1,MarcadorVirtual\WObj:=wobj0;
        
    ENDPROC
    PROC Path_10()
        MoveL Target_aprox2,v60,z1,MarcadorVirtual\WObj:=wobj0;
        MoveL Target_10,v60,z1,MarcadorVirtual\WObj:=wobj_JMora;
    ENDPROC
    PROC Path_20()
        MoveL Target_540,v60,z1,MarcadorVirtual\WObj:=wobj_JMora;
        MoveL Target_550,v60,z1,MarcadorVirtual\WObj:=wobj_JMora;
    ENDPROC
    PROC Path_home()
        MoveL Target_home,v100,z1,MarcadorVirtual\WObj:=wobj0;
    ENDPROC
